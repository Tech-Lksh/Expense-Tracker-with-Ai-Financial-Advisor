# ============== SERVER ==============
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
API_VERSION=v1

# ============== DATABASE ==============
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/expense_tracker

# ============== REDIS (caching + BullMQ job queues) ==============
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ============== JWT AUTH ==============
JWT_ACCESS_SECRET=744a4fab643ba1c98529366b6fa30f96519e5c95
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=b7282c7fd169de45dfc10ac8e11b87ca1a378573
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_DOMAIN=localhost

# ============== GOOGLE MAPS PLATFORM ==============
# Enable these APIs in Google Cloud Console: Geocoding API, Places API, Maps JavaScript API
GOOGLE_MAPS_API_KEY=replace_with_your_google_maps_api_key

# ============== RATE LIMITING ==============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ============== LOGGING ==============
LOG_LEVEL=info
